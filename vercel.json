{
  "name": "happy-hip",
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/register.html",
      "dest": "/register.html"
    },
    {
      "src": "/liff.html",
      "dest": "/liff.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}